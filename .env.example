# Local Cognee + Ollama is the demo default.
PATCHMIND_MEMORY_MODE=local
PATCHMIND_PREFLIGHT=true
PATCHMIND_PREFLIGHT_TIMEOUT_SECONDS=10
PATCHMIND_COGNEE_DATA_DIR=.patchmind/cognee/data
PATCHMIND_COGNEE_SYSTEM_DIR=.patchmind/cognee/system
PATCHMIND_RECALL_MODE=chunks
COGNEE_SKIP_CONNECTION_TEST=true

# Ollama exposes an OpenAI-compatible chat API at /v1.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:7b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MAX_COMPLETION_TOKENS=4096
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_DIMENSIONS=768

# Cloud mode is opt-in. The tenant must expose POST /api/v1/improve.
COGNEE_SERVICE_URL=
COGNEE_API_KEY=
PATCHMIND_MAX_FILE_BYTES=100000
PATCHMIND_MAX_COMMITS=50
PATCHMIND_TRANSPORT=streamable-http
PATCHMIND_HOST=0.0.0.0
PATCHMIND_PORT=8000
